generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Work {
  id          Int      @id @default(autoincrement())
  title       String
  desc        String?
  category    String
  image       String?
  tech        String?
  url         String?
  extra       String?
  createdAt   DateTime @default(now())
}

model Profile {
  id      Int    @id @default(autoincrement())
  name    String
  job     String
  intro   String
  skills  String
  contact String
}